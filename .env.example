# ── Supabase (required for cloud saves and auth) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Azgaar FMG (optional, enables World Map tab) ──────────────────────────────
VITE_FMG_URL=https://map.yourdomain.com

# ── Analytics provider (optional — pick ONE) ──────────────────────────────────
# Tier 8.8 funnel events fire to window.__sf_analytics_provider; setting one of
# these env vars installs a provider that bridges to a real dashboard.
#
# Plausible (privacy-first, no cookies, no consent banner needed for EU):
# VITE_PLAUSIBLE_DOMAIN=settlementforge.com
# VITE_PLAUSIBLE_API=https://plausible.io        # only for self-hosted Plausible
#
# PostHog (full product analytics; requires posthog-js + a consent gate):
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://app.posthog.com

# ── Client error reporting (optional) ─────────────────────────────────────────
# The client error reporter (src/lib/errorReporter.js) ALWAYS logs render
# crashes + unhandled rejections locally. It only forwards a compact, PII-light
# JSON payload over the network when this is set, so it is a no-op (network-wise)
# until you point it at a sink. Use any HTTPS endpoint: a Supabase edge function,
# a Sentry tunnel, Logflare, etc.
# VITE_ERROR_REPORT_URL=https://your-sink.example.com/errors

# ── Supabase Edge Function secrets (set in Supabase dashboard, not here) ──────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_CREDITS_10=price_...
# STRIPE_PRICE_CREDITS_50=price_...
# STRIPE_PRICE_PREMIUM=price_...
# ANTHROPIC_API_KEY=sk-ant-...
# CLIENT_URL=https://yourapp.com
# RESEND_API_KEY=re_...                              # Tier 8.5 — lifecycle emails
# RESEND_FROM_EMAIL="SettlementForge <hello@settlementforge.com>"
