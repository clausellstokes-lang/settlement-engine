# legacy-peer-deps is required by ONE dev dependency: eslint-plugin-jsx-a11y@6.10.2
# declares a peer range of `eslint@^3 || … || ^9` and has not yet published ESLint
# 10 support, while this repo is on eslint@10. The plugin works correctly under
# ESLint 10's flat config in practice; the flag accepts that known, intentional
# peer mismatch. (The now-removed eslint-plugin-react was a second, dead source of
# the same conflict.) Revisit — and drop this flag — when jsx-a11y widens its peer
# range to include ESLint 10.
legacy-peer-deps=true
