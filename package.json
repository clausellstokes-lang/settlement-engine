{
  "name": "settlementforge",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "validate:data": "node scripts/find-duplicate-keys.js",
    "fix:data": "node scripts/fix-duplicate-keys.js",
    "build:edge-shared": "node scripts/build-edge-shared.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.full.json",
    "typecheck:domain": "tsc --noEmit",
    "lint": "eslint src/ tests/ scripts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "check": "npm run validate:data && npm run typecheck && npm run lint && npm run test && npm run build",
    "check:quick": "npm run lint && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.103.0",
    "immer": "^11.1.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.383.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "seedrandom": "^3.0.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
